---
layout: null
---
{
    "items": [
        {% for item in site.items %}
        {
            "title": "{{ item.title | xml_escape }}",
            "url": "{{ site.url }}{{ item.url }}",
            "date": "{{ item.date | date_to_xmlschema }}"
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
    ]
}